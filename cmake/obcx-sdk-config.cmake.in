@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Public dependencies required by obcx_core
find_dependency(Boost COMPONENTS thread locale)
find_dependency(nlohmann_json CONFIG)
find_dependency(spdlog CONFIG)
find_dependency(fmt CONFIG)
find_dependency(OpenSSL)
find_dependency(ZLIB)
find_dependency(tomlplusplus CONFIG)
find_dependency(ftxui CONFIG)

# Include the exported targets
include("${CMAKE_CURRENT_LIST_DIR}/obcx-sdk-targets.cmake")

check_required_components(obcx-sdk)
